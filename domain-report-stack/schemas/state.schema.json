{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://openclaw.local/domain-report-stack/state.schema.json",
  "title": "domain-report-stack state.json",
  "type": "object",
  "required": ["schema_version", "project_slug", "stages"],
  "additionalProperties": false,
  "properties": {
    "schema_version": {
      "type": "integer",
      "minimum": 1
    },
    "project_slug": {
      "type": "string"
    },
    "stages": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "status", "wv_refs"],
        "additionalProperties": false,
        "properties": {
          "id": {
            "type": "string",
            "enum": [
              "intake",
              "strategic",
              "adversarial",
              "domain_deep",
              "synthesis",
              "quality",
              "preflight",
              "ship"
            ]
          },
          "status": {
            "type": "string",
            "enum": ["pending", "done"]
          },
          "wv_refs": {
            "type": "array",
            "items": { "type": "string" },
            "description": "WV paths referenced in this stage"
          },
          "updated_at": {
            "type": "string",
            "format": "date-time",
            "description": "ISO 8601 optional"
          }
        }
      }
    }
  }
}
